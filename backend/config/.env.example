# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=sqlite:///instance/okoaroute.db

# Africa's Talking API Credentials
AFRICAS_TALKING_USERNAME=sandbox
